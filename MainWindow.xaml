<Window x:Class="TarkovTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SayserTarkovTracker"
        Icon="app.ico"
        Height="900"
        Width="1440"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource TacticalBgDarkBrush}"
        FontFamily="{StaticResource TacticalFont}">

    <DockPanel LastChildFill="True">

        <!-- Top command bar -->
        <Border DockPanel.Dock="Top"
                Background="#121610"
                BorderBrush="{StaticResource TacticalAmberDimBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28"
                            BorderBrush="{StaticResource TacticalAmberBrush}"
                            BorderThickness="1"
                            Margin="0,0,10,0">
                        <Grid>
                            <Line X1="14" Y1="4" X2="14" Y2="24" Stroke="{StaticResource TacticalAmberBrush}" StrokeThickness="1"/>
                            <Line X1="4" Y1="14" X2="24" Y2="14" Stroke="{StaticResource TacticalAmberBrush}" StrokeThickness="1"/>
                            <Ellipse Width="6" Height="6" Stroke="{StaticResource TacticalAmberBrush}" StrokeThickness="1"/>
                        </Grid>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SAYSERTARKOVTRACKER"
                                   Foreground="{StaticResource TacticalTextPrimaryBrush}"
                                   FontSize="13"
                                   FontWeight="Bold"/>
                        <TextBlock Text="TACTICAL MAP INTERFACE v1.0"
                                   Foreground="{StaticResource TacticalTextMutedBrush}"
                                   FontSize="9"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="MAP SELECT"
                               Style="{StaticResource TacticalLabel}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox x:Name="MapComboBox"
                              Style="{StaticResource TacticalComboBox}"
                              Width="200"
                              SelectionChanged="MapComboBox_SelectionChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="SCREENSHOT FOLDER"
                            Style="{StaticResource TacticalButton}"
                            Click="SetScreenshotFolder_Click"/>
                    <Button Content="OPEN FOLDER"
                            Style="{StaticResource TacticalButton}"
                            Click="OpenScreenshotFolder_Click"/>
                    <Button Content="READ LATEST"
                            Style="{StaticResource TacticalButton}"
                            Click="ReadLatestScreenshot_Click"/>
                    <Button Content="RESET VIEW"
                            Style="{StaticResource TacticalButton}"
                            Click="ResetView_Click"/>
                    <Button Content="OVERLAY"
                            Style="{StaticResource TacticalButton}"
                            Margin="0"
                            Click="OpenOverlayButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#0A0C08"
                BorderBrush="{StaticResource TacticalAmberDimBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&gt; _"
                               FontFamily="{StaticResource TacticalMonoFont}"
                               Foreground="{StaticResource TacticalTerminalGreenBrush}"
                               FontSize="13"
                               Margin="0,0,6,0"/>
                    <TextBlock x:Name="ParserStatusText"
                               Text="PARSER: WAITING"
                               FontFamily="{StaticResource TacticalMonoFont}"
                               Foreground="{StaticResource TacticalTerminalGreenBrush}"
                               FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DATA SOURCE: SCREENSHOT"
                               Style="{StaticResource TacticalLabel}"
                               Margin="0,0,16,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="READY"
                               Style="{StaticResource TacticalLabel}"
                               Foreground="{StaticResource TacticalTextPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Background="{StaticResource TacticalBgDarkBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Map viewport -->
            <Border Grid.Column="0" Style="{StaticResource TacticalMapFrame}">
                <Border Background="{StaticResource TacticalBgInsetBrush}"
                        BorderBrush="{StaticResource TacticalAmberDimBrush}"
                        BorderThickness="1">
                    <wv2:WebView2 x:Name="MapWebView"/>
                </Border>
            </Border>

            <!-- Right sidebar -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="0,10,10,10">
                <StackPanel Margin="0,0,4,0">

                    <!-- Screenshot data -->
                    <Border Style="{StaticResource TacticalPanel}">
                        <StackPanel>
                            <TextBlock Text="SCREENSHOT DATA" Style="{StaticResource TacticalSectionHeader}"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0">
                                    <TextBlock Text="COORD X" Style="{StaticResource TacticalLabel}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource TacticalLcdBox}">
                                        <TextBlock x:Name="GameXText" Text="-" Style="{StaticResource TacticalValue}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="COORD Y" Style="{StaticResource TacticalLabel}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource TacticalLcdBox}">
                                        <TextBlock x:Name="GameYText" Text="-" Style="{StaticResource TacticalValue}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="2">
                                    <TextBlock Text="ELEV Z" Style="{StaticResource TacticalLabel}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource TacticalLcdBox}">
                                        <TextBlock x:Name="GameZText" Text="-" Style="{StaticResource TacticalValue}"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Grid.Row="2">
                                    <TextBlock Text="BEARING" Style="{StaticResource TacticalLabel}" Margin="0,0,0,4"/>
                                    <Border Style="{StaticResource TacticalLcdBox}">
                                        <TextBlock x:Name="DirectionText" Text="-" Style="{StaticResource TacticalValue}" FontSize="18"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="ACTIVE MAP" Style="{StaticResource TacticalLabel}" Margin="0,4,0,4"/>
                            <TextBlock x:Name="CurrentMapText"
                                       Text="NONE"
                                       Foreground="{StaticResource TacticalAmberBrightBrush}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="CAPTURED" Style="{StaticResource TacticalLabel}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LastScreenshotText"
                                       Text="NONE"
                                       FontFamily="{StaticResource TacticalMonoFont}"
                                       Foreground="{StaticResource TacticalTextPrimaryBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Selected marker -->
                    <Border Style="{StaticResource TacticalPanel}">
                        <StackPanel>
                            <TextBlock Text="SELECTED MARKER" Style="{StaticResource TacticalSectionHeader}"/>
                            <TextBlock x:Name="SelectedMarkerNameText"
                                       Text="NONE"
                                       Foreground="{StaticResource TacticalAmberBrightBrush}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <TextBlock x:Name="SelectedMarkerDetailsText"
                                       Text="Click a marker on the map."
                                       Style="{StaticResource TacticalBody}"
                                       FontSize="11"
                                       Foreground="{StaticResource TacticalTextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Markers grid -->
                    <Border Style="{StaticResource TacticalPanel}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="MARKERS" Style="{StaticResource TacticalSectionHeader}" Margin="0"/>
                                <Button Content="SHOW ALL"
                                        Style="{StaticResource TacticalSmallButton}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Click="ShowAllMarkers_Click"/>
                            </Grid>

                            <UniformGrid Columns="4" Rows="3">

                                <CheckBox x:Name="ShowLabelsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <TextBlock Text="Location Names"
                                               FontSize="9"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                </CheckBox>

                                <CheckBox x:Name="ShowQuestItemsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="False"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/quest_item.png"/>
                                        <TextBlock Text="Quest Item" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowQuestObjectivesCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="False"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/quest_objective.png"/>
                                        <TextBlock Text="Quest Obj" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowPmcExtractsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/extract_pmc.png"/>
                                        <TextBlock Text="PMC Ext" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowScavExtractsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/extract_scav.png"/>
                                        <TextBlock Text="Scav Ext" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowSharedExtractsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/extract_shared.png"/>
                                        <TextBlock Text="Shared" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowTransitsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/extract_transit.png"/>
                                        <TextBlock Text="Transit" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowHazardsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/hazard.png"/>
                                        <TextBlock Text="Hazard" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowSwitchesCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="True"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/switch.png"/>
                                        <TextBlock Text="Switch" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowPmcSpawnsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="False"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/spawn_pmc.png"/>
                                        <TextBlock Text="PMC Spawn" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowScavSpawnsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="False"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/spawn_scav.png"/>
                                        <TextBlock Text="Scav Spawn" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox x:Name="ShowBossSpawnsCheckBox"
                                          Style="{StaticResource TacticalMarkerTile}"
                                          IsChecked="False"
                                          Checked="MarkerFilter_Changed"
                                          Unchecked="MarkerFilter_Changed">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Image Width="24" Height="24"
                                               Source="pack://siteoforigin:,,,/Maps/interactive/spawn_boss.png"/>
                                        <TextBlock Text="Boss" FontSize="8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Levels -->
                    <Border Style="{StaticResource TacticalPanel}" Margin="0">
                        <StackPanel>
                            <Grid x:Name="LevelsHeaderGrid" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="LEVELS"
                                           Style="{StaticResource TacticalSectionHeader}"
                                           VerticalAlignment="Center"
                                           Margin="0"/>

                                <Button Grid.Column="1"
                                        Content="ALL"
                                        Style="{StaticResource TacticalSmallButton}"
                                        Width="40"
                                        Margin="0,0,6,0"
                                        Click="ShowAllLayers_Click"/>

                                <Button Grid.Column="2"
                                        Content="NONE"
                                        Style="{StaticResource TacticalSmallButton}"
                                        Width="48"
                                        Click="HideAllLayers_Click"/>
                            </Grid>

                            <WrapPanel x:Name="LayersPanel"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </DockPanel>
</Window>
