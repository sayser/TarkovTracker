<Window x:Class="TarkovTracker.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="SayserTarkovTracker Overlay"
        Width="800"
        Height="800"
        MinWidth="300"
        MinHeight="300"
        WindowStyle="None"
        ResizeMode="CanResize"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        FontFamily="{StaticResource TacticalFont}">

    <Grid>
        <!-- Glass panel -->
        <Border x:Name="OverlayRootBorder"
                CornerRadius="12"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                Background="{StaticResource GlassPanelBrush}"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.45"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Glass title pill bar -->
                <Border Grid.Row="0"
                        Background="{StaticResource GlassTitleBarBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="12,12,0,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Opacity="0.5">
                                <Ellipse Width="4" Height="4" Fill="#C4A35A" Margin="0,0,3,0"/>
                                <Ellipse Width="4" Height="4" Fill="#C4A35A" Margin="0,0,3,0"/>
                                <Ellipse Width="4" Height="4" Fill="#C4A35A"/>
                            </StackPanel>
                            <TextBlock Text="OVERLAY"
                                       Foreground="{StaticResource TacticalAmberBrightBrush}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="OPACITY"
                                       Foreground="{StaticResource TacticalTextMutedBrush}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <Slider x:Name="OpacitySlider"
                                    Width="100"
                                    Minimum="20"
                                    Maximum="100"
                                    Value="80"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0"
                                    ValueChanged="OpacitySlider_ValueChanged"/>

                            <Button Content="✕"
                                    Width="22"
                                    Height="22"
                                    FontSize="11"
                                    Foreground="{StaticResource TacticalTextMutedBrush}"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    Click="CloseButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="11">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#40FF4444"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6B4A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Background="Transparent">
                    <wv2:WebView2 x:Name="OverlayMapView"
                                  DefaultBackgroundColor="Transparent"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Resize hit targets -->
        <Border Width="6" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWE"
                Tag="Left" MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Width="6" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWE"
                Tag="Right" MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Height="6" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNS"
                Tag="Top" MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Height="6" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNS"
                Tag="Bottom" MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                Background="Transparent" Cursor="SizeNWSE" Tag="TopLeft"
                MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top"
                Background="Transparent" Cursor="SizeNESW" Tag="TopRight"
                MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Tag="BottomLeft"
                MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
        <Border Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Tag="BottomRight"
                MouseLeftButtonDown="ResizeEdge_MouseLeftButtonDown"/>
    </Grid>
</Window>
