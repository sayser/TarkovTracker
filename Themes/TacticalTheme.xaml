<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette -->
    <Color x:Key="TacticalBgDark">#0D0F0A</Color>
    <Color x:Key="TacticalBgPanel">#141812</Color>
    <Color x:Key="TacticalBgInset">#0A0C08</Color>
    <Color x:Key="TacticalAmber">#C4A35A</Color>
    <Color x:Key="TacticalAmberBright">#E8C872</Color>
    <Color x:Key="TacticalAmberDim">#6B5830</Color>
    <Color x:Key="TacticalTextPrimary">#E8DCC8</Color>
    <Color x:Key="TacticalTextMuted">#8A8274</Color>
    <Color x:Key="TacticalTerminalGreen">#57FF57</Color>
    <Color x:Key="TacticalTerminalRed">#FF6B4A</Color>

    <SolidColorBrush x:Key="TacticalBgDarkBrush" Color="{StaticResource TacticalBgDark}"/>
    <SolidColorBrush x:Key="TacticalBgPanelBrush" Color="{StaticResource TacticalBgPanel}"/>
    <SolidColorBrush x:Key="TacticalBgInsetBrush" Color="{StaticResource TacticalBgInset}"/>
    <SolidColorBrush x:Key="TacticalAmberBrush" Color="{StaticResource TacticalAmber}"/>
    <SolidColorBrush x:Key="TacticalAmberBrightBrush" Color="{StaticResource TacticalAmberBright}"/>
    <SolidColorBrush x:Key="TacticalAmberDimBrush" Color="{StaticResource TacticalAmberDim}"/>
    <SolidColorBrush x:Key="TacticalTextPrimaryBrush" Color="{StaticResource TacticalTextPrimary}"/>
    <SolidColorBrush x:Key="TacticalTextMutedBrush" Color="{StaticResource TacticalTextMuted}"/>
    <SolidColorBrush x:Key="TacticalTerminalGreenBrush" Color="{StaticResource TacticalTerminalGreen}"/>
    <SolidColorBrush x:Key="TacticalTerminalRedBrush" Color="{StaticResource TacticalTerminalRed}"/>

    <!-- Glass overlay -->
    <SolidColorBrush x:Key="GlassPanelBrush" Color="#1A1D18" Opacity="0.82"/>
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#FFFFFF" Opacity="0.18"/>
    <SolidColorBrush x:Key="GlassTitleBarBrush" Color="#0D0F0A" Opacity="0.65"/>

    <FontFamily x:Key="TacticalFont">Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="TacticalMonoFont">Consolas, Courier New</FontFamily>

    <!-- Section header -->
    <Style x:Key="TacticalSectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrush}"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="TacticalLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
    </Style>

    <Style x:Key="TacticalValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TacticalMonoFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
    </Style>

    <Style x:Key="TacticalBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Tactical panel frame -->
    <Style x:Key="TacticalPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TacticalBgPanelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- Map viewport frame (double-line effect via outer border) -->
    <Style x:Key="TacticalMapFrame" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TacticalBgInsetBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Margin" Value="10"/>
    </Style>

    <!-- LCD readout box -->
    <Style x:Key="TacticalLcdBox" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TacticalBgInsetBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>

    <!-- Toolbar / tactical button -->
    <Style x:Key="TacticalButton" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimaryBrush}"/>
        <Setter Property="Background" Value="#1E221C"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2A3028"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0A0C08"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TacticalSmallButton" TargetType="Button" BasedOn="{StaticResource TacticalButton}">
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="TacticalTextBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource TacticalMonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
        <Setter Property="Background" Value="{StaticResource TacticalBgInsetBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <Style x:Key="TacticalDangerButton" TargetType="Button" BasedOn="{StaticResource TacticalButton}">
        <Setter Property="Foreground" Value="{StaticResource TacticalTerminalRedBrush}"/>
        <Setter Property="BorderBrush" Value="#804030"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <Style x:Key="TacticalSettingsCheckBox" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalTextPrimaryBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <!-- ComboBox -->
    <Style x:Key="TacticalComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
        <Setter Property="Background" Value="{StaticResource TacticalBgInsetBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- Level chip (CheckBox styled as toggle tab) -->
    <Style x:Key="TacticalLevelChip" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
        <Setter Property="Background" Value="#1A1D18"/>
        <Setter Property="BorderBrush" Value="{StaticResource TacticalAmberDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="0,0,6,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2A2418"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Marker tile checkbox -->
    <Style x:Key="TacticalMarkerTile" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TacticalTextMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource TacticalFont}"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Border x:Name="Tile"
                            Background="#1A1D18"
                            BorderBrush="{StaticResource TacticalAmberDimBrush}"
                            BorderThickness="1"
                            MinHeight="72"
                            MinWidth="72">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,8,0,0"/>
                            <Border Width="14" Height="14"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="4"
                                    BorderBrush="{StaticResource TacticalAmberDimBrush}"
                                    BorderThickness="1"
                                    Background="#0A0C08">
                                <Path x:Name="CheckMark"
                                      Data="M 1,4 L 4,7 L 9,1"
                                      Stroke="{StaticResource TacticalAmberBrightBrush}"
                                      StrokeThickness="2"
                                      Visibility="Collapsed"
                                      Margin="1"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
                            <Setter TargetName="Tile" Property="Background" Value="#222018"/>
                            <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Tile" Property="BorderBrush" Value="{StaticResource TacticalAmberBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox dropdown items -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource TacticalBgPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TacticalAmberBrightBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- ScrollBar dark -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource TacticalBgInsetBrush}"/>
    </Style>

</ResourceDictionary>
